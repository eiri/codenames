{
  "name": "codenames",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host --port 5173",
    "build": "vite build",
    "test": "vitest run",
    "lint": "eslint -c eslint.config.ts src",
    "dev-test": "vitest --reporter=basic --disable-console-intercept",
    "preview": "vite preview",
    "convert": "node ./assets/convert.js ./assets/ACB_codenames.txt ./src/assets/words.json",
    "encrypt": "node --import=specifier-resolution-node/register ./assets/encrypt.js"
  },
  "dependencies": {
    "ably": "^2.5.0",
    "crypto-es": "^3.1.3",
    "pinia": "^3.0.4",
    "specifier-resolution-node": "^1.1.4",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.0.8",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "typescript-eslint": {
      "typescript": "^6"
    }
  }
}
